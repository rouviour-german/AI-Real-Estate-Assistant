# AI Real Estate Assistant - Environment Variables
# Copy this file to .env and fill in your API keys
#
# Monorepo Structure (Vercel Full-Stack Deployment):
# - apps/web/    : Next.js frontend
# - apps/api/    : FastAPI backend (Python serverless)

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
ENVIRONMENT=development
NODE_ENV=development

# Frontend (Next.js)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# LLM PROVIDER API KEYS (at least one required)
# =============================================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
XAI_API_KEY=...
DEEPSEEK_API_KEY=...

# Default LLM Provider (openai, anthropic, google, xai, deepseek, ollama)
DEFAULT_PROVIDER=openai

# Optional: Ollama API base URL (for local models)
# OLLAMA_API_BASE=http://localhost:11434

# LLM Request Timeouts (seconds)
# LLM_REQUEST_TIMEOUT_SECONDS=120
# LLM_CONNECT_TIMEOUT_SECONDS=30

# =============================================================================
# API SECURITY (REQUIRED)
# =============================================================================
# V4 API access key (FastAPI) - REQUIRED for all environments
# SECURITY: No default fallback. Generate a strong key using: openssl rand -hex 32
API_ACCESS_KEY=your-generated-api-key-here

# Rate limiting (optional)
# API_RATE_LIMIT_ENABLED=true
# API_RATE_LIMIT_RPM=600

# Optional: Comma-separated keys for rotation
# API_ACCESS_KEYS=new-key,old-key

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Enable JWT-based user authentication
# AUTH_JWT_ENABLED=true

# JWT Secret Key (REQUIRED if AUTH_JWT_ENABLED=true)
# SECURITY: Generate using: openssl rand -hex 32
# JWT_SECRET_KEY=your-jwt-secret-key-here

# JWT Token Configuration
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database for user auth (defaults to SQLite if not set)
# DATABASE_URL=sqlite+aiosqlite:///./data/auth.db
# For PostgreSQL: postgresql+asyncpg://user:pass@host:5432/auth

# Feature Flags
# AUTH_REGISTRATION_ENABLED=true
# AUTH_EMAIL_VERIFICATION_REQUIRED=true

# Frontend URL for email links (verification, password reset)
# FRONTEND_URL=http://localhost:3000

# =============================================================================
# OAUTH - GOOGLE
# =============================================================================
# Enable Google OAuth login
# AUTH_OAUTH_GOOGLE_ENABLED=true

# Google OAuth credentials (from Google Cloud Console)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# Must match authorized redirect URI in Google Cloud Console
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/callback

# =============================================================================
# OAUTH - APPLE (Optional)
# =============================================================================
# Enable Apple Sign-In
# AUTH_OAUTH_APPLE_ENABLED=false

# APPLE_CLIENT_ID=com.yourapp.web
# APPLE_TEAM_ID=XXXXXXXXXX
# APPLE_KEY_ID=XXXXXXXXXX
# APPLE_PRIVATE_KEY_PATH=/secrets/AuthKey_XXXXXXXXXX.p8

# =============================================================================
# BACKEND API URL (Local Development Only)
# =============================================================================
# For Vercel full-stack deployment, this is NOT needed - routing is handled by vercel.json
# For local development, the Next.js API proxy (apps/web/src/app/api/v1/[...path]/route.ts)
# forwards requests to the backend.
# BACKEND_API_URL=http://localhost:8000/api/v1

# =============================================================================
# CORS CONFIGURATION (Production)
# =============================================================================
# ENVIRONMENT=production
# CORS_ALLOW_ORIGINS=https://yourapp.com,https://studio.vercel.app

# =============================================================================
# OPTIONAL FEATURES
# =============================================================================
# Email Configuration (for notifications)
# SMTP_USERNAME=your.email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# SMTP_PROVIDER=gmail

# Google Routes API for commute time analysis
# Get your API key at: https://developers.google.com/maps/routes
# GOOGLE_ROUTES_API_KEY=your-google-routes-api-key-here
# GOOGLE_ROUTES_ENABLED=true

# Redis (MCP/caching/session)
# REDIS_URL=redis://localhost:6379

# Uptime Monitor (optional)
# UPTIME_MONITOR_ENABLED=true
# UPTIME_MONITOR_HEALTH_URL=http://localhost:8000/health
# UPTIME_MONITOR_EMAIL_TO=ops@example.com
# UPTIME_MONITOR_INTERVAL=60
# UPTIME_MONITOR_FAIL_THRESHOLD=3
# UPTIME_MONITOR_COOLDOWN_SECONDS=1800

# =============================================================================
# VECTOR STORE CONFIGURATION
# =============================================================================
# ChromaDB persistence directory (relative to apps/api/)
# CHROMA_PERSIST_DIR=./vector_store/chroma
