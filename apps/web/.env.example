# Frontend (Next.js) Environment Variables
# Copy this file to .env.local for local development

# =============================================================================
# Public Environment Variables (Client-Side)
# These are exposed to the browser and should NOT contain secrets
# =============================================================================

# API endpoint path (default: /api/v1 for Next.js proxy)
# In production with Vercel, this stays as /api/v1 to use the Next.js API proxy
NEXT_PUBLIC_API_URL=/api/v1

# Mapbox public access token (for enhanced mapping features)
# Get your token at: https://account.mapbox.com/
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijo...

# =============================================================================
# Server-Side Environment Variables (Private)
# These are only used on the server and NOT exposed to the browser
# =============================================================================

# Backend API URL (for Next.js API proxy)
# - Local development: http://localhost:8000/api/v1
# - Production (Vercel Preview): https://your-backend-preview.vercel.app/api/v1
# - Production (Vercel Production): https://your-backend-production.com/api/v1
BACKEND_API_URL=http://localhost:8000/api/v1

# API Access Key (for backend authentication)
# Must match the backend's API_ACCESS_KEY
# Generate with: openssl rand -hex 32
# IMPORTANT: Set this in Vercel dashboard (Environment Variables), not in .env.local
API_ACCESS_KEY=your-generated-api-key-here

# Optional: Multiple API keys for rotation
# API_ACCESS_KEYS=new-key,old-key
