# Docker Compose Environment Variables
# Copy this file to .env in the same directory as docker-compose.yml
# Or set variables in the project root .env file

# =============================================================================
# REQUIRED: At least one LLM provider API key
# =============================================================================
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# XAI_API_KEY=...
# DEEPSEEK_API_KEY=...

# =============================================================================
# REQUIRED: API Security
# =============================================================================
# Generate with: openssl rand -hex 32
API_ACCESS_KEY=your-generated-api-key-here

# Optional: Multiple API keys for rotation (comma-separated)
# API_ACCESS_KEYS=new-key,old-key

# =============================================================================
# OPTIONAL: Application Settings
# =============================================================================
ENVIRONMENT=development
DEFAULT_PROVIDER=openai

# CORS origins (comma-separated, no spaces)
# CORS_ALLOW_ORIGINS=http://localhost:3000,https://yourapp.com

# =============================================================================
# OPTIONAL: Local LLM with Ollama (use --profile local-llm)
# =============================================================================
# OLLAMA_DEFAULT_MODEL=llama3.2:3b
# OLLAMA_API_BASE=http://ollama:11434

# =============================================================================
# OPTIONAL: Web Search with SearXNG (use --profile internet)
# =============================================================================
# SEARXNG_BASE_URL=http://searxng:8080/
# SEARXNG_SECRET=<generate-with-openssl-rand-hex-32>

# WARNING: Change SEARXNG_SECRET from default 'change-me' for production!
# The default value in docker-compose.yml is insecure.

# =============================================================================
# OPTIONAL: Caching & Metrics
# =============================================================================
# CACHE_ENABLED=true
# CACHE_TTL_SECONDS=300
# CACHE_REDIS_URL=redis://redis:6379
# METRICS_ENABLED=true

# =============================================================================
# OPTIONAL: Frontend Settings (for Docker)
# =============================================================================
# NEXT_PUBLIC_API_URL=/api/v1
# BACKEND_API_URL=http://backend:8000/api/v1
